{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "disabled_providers": [
    "zen",
    "anthropic"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "**/credentials/**": "deny",
      "**/credentials.json": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.crt": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*.keystore": "deny",
      "**/application-secret*.yml": "deny",
      "**/application-secret*.yaml": "deny",
      "**/application-secret*.properties": "deny",
      "~/.ssh/**": "deny",
      "**/.ssh/**": "deny"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "**/credentials/**": "deny",
      "**/node_modules/**": "deny",
      "*.lock": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.crt": "deny",
      "**/generated/**": "ask",
      "**/build/**": "deny",
      "**/dist/**": "deny",
      "~/.ssh/**": "deny",
      "**/.ssh/**": "deny"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "which *": "allow",
      "ps *": "allow",
      "mkdir *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "diff *": "allow",
      "file *": "allow",
      "pwd*": "allow",
      "true*": "allow",
      "echo *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "realpath *": "allow",
      "test *": "allow",
      "[ *": "allow",
      "cat *.env*": "deny",
      "cat */.env*": "deny",
      "cat *secrets*": "deny",
      "cat *credentials*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "cat */.ssh/*": "deny",
      "cat ~/.ssh/*": "deny",
      "head *.env*": "deny",
      "head */.env*": "deny",
      "head *secrets*": "deny",
      "head *.pem": "deny",
      "head *.key": "deny",
      "head */.ssh/*": "deny",
      "tail *.env*": "deny",
      "tail */.env*": "deny",
      "tail *secrets*": "deny",
      "tail *.pem": "deny",
      "tail *.key": "deny",
      "tail */.ssh/*": "deny",
      "grep * *.env*": "deny",
      "grep * */.env*": "deny",
      "grep * *secrets*": "deny",
      "grep * *.pem": "deny",
      "grep * *.key": "deny",
      "grep * */.ssh/*": "deny",
      "cp */.ssh/*": "deny",
      "cp ~/.ssh/*": "deny",
      "mv */.ssh/*": "deny",
      "mv ~/.ssh/*": "deny",
      "rm */.ssh/*": "deny",
      "chmod */.ssh/*": "deny",
      "env": "ask",
      "env *": "ask",
      "printenv*": "ask",
      "npm list*": "allow",
      "npm ls*": "allow",
      "npm view*": "allow",
      "npm info*": "allow",
      "npm outdated*": "allow",
      "npm run *": "ask",
      "npm test*": "ask",
      "npm install*": "ask",
      "npm i *": "ask",
      "npm ci*": "ask",
      "npm exec*": "ask",
      "npm publish*": "deny",
      "npx *": "ask",
      "nvm list*": "allow",
      "nvm ls*": "allow",
      "nvm current*": "allow",
      "nvm version*": "allow",
      "nvm use *": "ask",
      "nvm install *": "ask",
      "mvn --version*": "allow",
      "mvn dependency:tree*": "allow",
      "mvn dependency:list*": "allow",
      "mvn help:*": "allow",
      "mvn validate*": "allow",
      "mvn *": "ask",
      "./mvnw --version*": "allow",
      "./mvnw dependency:tree*": "allow",
      "./mvnw dependency:list*": "allow",
      "./mvnw help:*": "allow",
      "./mvnw validate*": "allow",
      "./mvnw *": "ask",
      "make *": "ask",
      "sqlfluff *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "git remote*": "allow",
      "git fetch*": "allow",
      "git stash list*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git config --get *": "allow",
      "git config --list*": "allow",
      "git add *": "allow",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git commit *": "ask",
      "git stash*": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git cherry-pick *": "ask",
      "git tag *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "git reset --hard *": "ask",
      "git reset --hard": "ask",
      "git clean *": "ask",
      "git *": "ask",
      "gh pr view*": "allow",
      "gh pr list*": "allow",
      "gh pr status*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",
      "gh issue status*": "allow",
      "gh repo view*": "allow",
      "gh api repos/*/comments/*/replies *": "allow",
      "gh pr create *": "allow",
      "gh pr comment*": "ask",
      "gh pr merge*": "ask",
      "gh pr close*": "ask",
      "gh pr edit*": "ask",
      "gh pr review*": "ask",
      "gh issue create*": "ask",
      "gh issue close*": "ask",
      "gh issue edit*": "ask",
      "gh *delete*": "deny",
      "gh *DELETE*": "deny",
      "gh *Delete*": "deny",
      "gh api -X DELETE *": "deny",
      "gh org *": "deny",
      "gh secret *": "deny",
      "gh auth *": "deny",
      "gh ssh-key *": "deny",
      "gh gpg-key *": "deny",
      "gh *": "ask",
      "az *": "ask",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "rm -fr /": "deny",
      "rm -fr /*": "deny",
      "rm -fr ~*": "deny",
      "rm -rf *": "ask",
      "rm -fr *": "ask",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "docker *": "ask",
      "kubectl *": "ask",
      "pip install*": "ask",
      "pip3 install*": "ask",
      "python -m pip*": "ask",
      "brew *": "ask",
      "sudo *": "deny",
      "su *": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "shutdown *": "deny",
      "reboot *": "deny",
      "halt *": "deny",
      "poweroff *": "deny",
      "dd *": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "parted *": "deny"
    },
    "external_directory": "ask",
    "doom_loop": "ask",
    "webfetch": "ask",
    "websearch": "allow",
    "codesearch": "allow",
    "task": "allow",
    "skill": "allow"
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "secrets/**",
      "**/.env*",
      "**/.ssh/**",
      "*.pem",
      "*.key"
    ]
  },
  "share": "disabled",
  "lsp": {
    "kotlin-ls": {
      "command": [
        "kotlin-lsp",
        "--stdio"
      ],
      "extensions": [
        ".kt",
        ".kts"
      ]
    },
    "kotlin-lsp": {
      "command": [
        "kotlin-lsp",
        "--stdio"
      ],
      "extensions": [
        ".kt",
        ".kts"
      ]
    }
  },
  "command": {
    "create-pr": {
      "template": "Create a draft PR for the changes in the current branch. The PR should be created against the main branch. The PR title should be a concise summary of the changes, and the PR description should include a detailed explanation of the changes, the reasoning behind them, and any relevant context. If there are any specific areas of the code that require attention or review, please highlight them in the description.",
      "description": "Create a draft PR for the current branch"
    },
    "review-code": {
      "template": "Ask @oracle to do a code review. Create an actionable plan with your recommendations and suggestions based on the findins. Ask for my feedback and approval before updating any code based on the plan.",
      "description": "Do a code review with @oracle"
    },
    "review-pr-comments": {
      "template": "Use the receiving-code-review skill to review PR comments. Ask for feedback and approval before updating any code based on the received reviews.",
      "description": "Review PR comments"
    },
    "review-pr": {
      "template": "Ask @oracle to review the code introduced in PR $1. If any actionable issues are found, add one comment to the PR for each issue with a summary and possible discussion points for the PR authtor. When adding comments, always try to add them to the correct line(s) in the PR code diff.",
      "description": "Review PR"
    }
  }
}
